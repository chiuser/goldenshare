[Unit]
Description=Goldenshare Ops Scheduler
After=network.target

[Service]
WorkingDirectory=/opt/goldenshare
Environment=GOLDENSHARE_ENV_FILE=/etc/goldenshare/web.env
ExecStart=/opt/goldenshare/.venv/bin/goldenshare ops-scheduler-serve
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
